<Window x:Class="RailCAD.Views.PointSelectionDialog"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RailCAD.Views"
        xmlns:res="clr-namespace:RailCAD.Properties"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}" MinHeight="175" Height="Auto" Width="320" 
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        SizeToContent="Height">

    <Window.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinWidth" Value="70" />
        </Style>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="3" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Point numbers input -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Resources.DialogPointSelection_PointNumbersOrRange}" />
        <TextBox Grid.Row="0" Grid.Column="1" 
                 Text="{Binding PointNumbersText, UpdateSourceTrigger=PropertyChanged}"
                 MaxHeight="60"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 GotFocus="PointNumbersText_GotFocus" />

        <!-- Filter input -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Resources.DialogPointSelection_TagFilter}" />
        <TextBox Grid.Row="1" Grid.Column="1" 
                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                 MaxHeight="60"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 GotFocus="FilterTextBox_GotFocus" />

        <!-- Show button -->
        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                Content="{x:Static res:Resources.Show}"
                HorizontalAlignment="Center"
                Margin="3"
                Command="{Binding ShowCommand}" />

        <!-- Button panel -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,3,0,0">
            <Button Content="OK" Command="{Binding OkCommand}" IsDefault="True" />
            <Button Content="{x:Static res:Resources.Cancel}" Command="{Binding CancelCommand}" IsCancel="True" />
            <Button Content="{x:Static res:Resources.Help}" Command="{Binding HelpCommand}" />
        </StackPanel>
    </Grid>
</Window>
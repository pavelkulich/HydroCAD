<Window x:Class="RailCAD.Views.LicenceActivationDialog"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RailCAD.Views"
        xmlns:res="clr-namespace:RailCAD.Properties"
        mc:Ignorable="d"
        Title="{x:Static res:Resources.LicenceActivationDialogName}" Height="380" Width="650"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBox" x:Key="CodeTextBoxStyle">
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4*" MinHeight="95"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4*" MinHeight="80"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Text -->
        <TextBlock Grid.Row="0" 
                   Text="{x:Static res:Resources.LicenceActivationStart}"
                   TextWrapping="Wrap"
                   FontWeight="SemiBold"
                   Margin="0,0,0,5"/>

        <!-- Activation Code TextBox -->
        <Border Grid.Row="1" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1" 
                Background="#F5F5F5"
                Margin="0,0,0,5">
            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                         HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,0">
                <TextBox x:Name="ActivationCodeTextBox"
                         Text="{Binding ActivationCode, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         BorderThickness="0"
                         Background="Transparent"
                         Style="{StaticResource CodeTextBoxStyle}"
                         TextChanged="ActivationCodeTextBox_TextChanged" Height="85"/>
            </ScrollViewer>
        </Border>

        <!-- Copy Button and Open Website Button -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Button Content="{x:Static res:Resources.LicenceCopyCode}"
                    Click="CopyCode_Click"
                    Width="150"/>
            <Button Content="{x:Static res:Resources.LicenceOpenWebsite}"
                    Click="OpenWebsite_Click"
                    Width="150"/>
        </StackPanel>


        <!-- Licence Key Label -->
        <TextBlock Grid.Row="3" 
                   Text="{x:Static res:Resources.LicencePasteKey}"
                   FontWeight="SemiBold"
                   Margin="0,10,0,10"/>

        <!-- Licence Key TextBox -->
        <Border Grid.Row="3" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1"
                Margin="0,30,0,0" Grid.RowSpan="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                         HorizontalScrollBarVisibility="Disabled">
                <TextBox x:Name="LicenceKeyTextBox"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         BorderThickness="0"
                         Style="{StaticResource CodeTextBoxStyle}"/>
            </ScrollViewer>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,5,0,0" Width="220">
            <Button Content="{x:Static res:Resources.OK}"
                    Click="OK_Click" 
                    IsDefault="True"/>
            <Button Content="{x:Static res:Resources.Cancel}"
                    Click="Cancel_Click" 
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>

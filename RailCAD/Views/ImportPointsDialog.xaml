<Window x:Class="RailCAD.Views.ImportPointsDialog"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RailCAD.Views"
        xmlns:res="clr-namespace:RailCAD.Properties"
        mc:Ignorable="d"
        Title="{x:Static res:Resources.DialogImportPoints_PointsImportFromTextFile}" Height="500" Width="700" 
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Style for buttons -->
        <Style TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="MinWidth" Value="80" />
        </Style>

        <!-- Style for text labels -->
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="5" />
        </Style>

        <!-- Style for text boxes -->
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Style for combo boxes -->
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- File selection -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{x:Static res:Resources.DialogImportPoints_FileName}" />
            <TextBox Grid.Column="1" Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" 
                     IsReadOnly="True" />
            <Button Grid.Column="2" Content="{x:Static res:Resources.DialogImportPoints_Browse}" Command="{Binding BrowseFileCommand}" />
        </Grid>

        <!-- Column configuration -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0" ItemsSource="{Binding ColumnTypes}" 
                      SelectedItem="{Binding SelectedColumnTypes[0]}" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding ColumnTypes}" 
                      SelectedItem="{Binding SelectedColumnTypes[1]}" />
            <ComboBox Grid.Column="2" ItemsSource="{Binding ColumnTypes}" 
                      SelectedItem="{Binding SelectedColumnTypes[2]}" />
            <ComboBox Grid.Column="3" ItemsSource="{Binding ColumnTypes}" 
                      SelectedItem="{Binding SelectedColumnTypes[3]}" />
            <ComboBox Grid.Column="4" ItemsSource="{Binding ColumnTypes}" 
                      SelectedItem="{Binding SelectedColumnTypes[4]}" />
        </Grid>

        <!-- File preview -->
        <TextBox Grid.Row="2" 
                 Text="{Binding FilePreview, Mode=OneWay}" 
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto" 
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 TextWrapping="NoWrap"
                 Background="#f5f5f5" Height="214" />

        <!-- Transformation settings -->
        <Grid Grid.Row="3" Margin="0,5,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Resources.DialogImportPoints_ScaleX}" />
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ScaleX, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="{x:Static res:Resources.DialogImportPoints_ShiftX}" />
            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding OffsetX, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Resources.DialogImportPoints_ScaleY}" />
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ScaleY, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="{x:Static res:Resources.DialogImportPoints_ShiftY}" />
            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding OffsetY, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Resources.DialogImportPoints_ScaleZ}" />
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ScaleZ, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="2" Grid.Column="2" Text="{x:Static res:Resources.DialogImportPoints_ShiftZ}" />
            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding OffsetZ, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="{x:Static res:Resources.Import}" Command="{Binding ImportCommand}" IsDefault="True" />
            <Button Content="{x:Static res:Resources.Cancel}" Command="{Binding CancelCommand}" IsCancel="True" />
            <Button Content="{x:Static res:Resources.Help}" Command="{Binding HelpCommand}" />
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="HydroCAD.Views.DrawProfileDialog"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Longitudinal Profile Settings" Height="440" Width="480"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="5,3" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="5,3" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="MinWidth" Value="80" />
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="MinWidth" Value="80" />
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Pipe properties -->
        <GroupBox Grid.Row="0" Header="Pipe Properties" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Pipe Diameter DN (mm):" />
                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Diameter}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Minimum Cover Depth (m):" />
                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding MinCoverDepth}" />
            </Grid>
        </GroupBox>

        <!-- Gradient / invert level -->
        <GroupBox Grid.Row="1" Header="Levels and Gradient" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Use fixed start invert (m):" />
                <CheckBox  Grid.Row="0" Grid.Column="1" IsChecked="{Binding UseStartInvertLevel}" VerticalAlignment="Center" Margin="5,3" />
                <TextBox   Grid.Row="0" Grid.Column="2" Text="{Binding StartInvertLevel}"
                           IsEnabled="{Binding UseStartInvertLevel}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Use fixed gradient (m/m):" />
                <CheckBox  Grid.Row="1" Grid.Column="1" IsChecked="{Binding UseFixedGradient}" VerticalAlignment="Center" Margin="5,3" />
                <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding FixedGradient}"
                           IsEnabled="{Binding UseFixedGradient}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Min gradient (m/m):" />
                <TextBox   Grid.Row="2" Grid.Column="2" Text="{Binding MinGradient}" />
            </Grid>
        </GroupBox>

        <!-- Sampling and scale -->
        <GroupBox Grid.Row="2" Header="Profile Drawing" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Sampling interval (m):" />
                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding SamplingInterval}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Horizontal scale (1:X):" />
                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding HorizontalScale}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Vertical scale (1:X):" />
                <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding VerticalScale}" />
            </Grid>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Generate Profile" Command="{Binding OkCommand}" IsDefault="True" />
            <Button Content="Cancel" Command="{Binding CancelCommand}" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
